spring:
  jmx:
    enabled: true

  application:
    name: algoduck

  datasource:
    url: jdbc:mysql://localhost:3306/algoduck_local_dev?serverTimezone=Asia/Seoul
    username: ${DB_USER_NAME}
    password: ${DB_PASSWORD}

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQL8Dialect

  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB
      max-request-size: 10MB

  cloud:
    aws:
      credentials:
        access-key: ${AWS_ACCESS_KEY}
        secret-key: ${AWS_SECRET_KEY}
      region:
        static: ap-northeast-2
      s3:
        testcase_bucket: ${S3_TESTCASE_BUCKET_NAME}
        profile_bucket: ${S3_PROFILE_BUCKET_NAME}
        submission_bucket: ${S3_SUBMISSION_BUCKET_NAME}

  rabbitmq:
    host: ${JUDGE_QUEUE_DOMAIN_NAME}
    port: 5672
    username: ${JUDGE_QUEUE_USERNAME}
    password: ${JUDGE_QUEUE_PASSWORD}
    ssl:
      enabled: false
      algorithm: TLSv1.2

rabbitmq:
  queue:
    request: judge-request
    progress: judge-progress
    result: judge-result

logging:
  file:
    name: /app/algoduck.log
  level:
    root: INFO
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE

app:
  default:
    profile-image-url: ${DEFAULT_PROFILE_URL}
    client-domain-name: ${CLIENT_DOMAIN_NAME}
    judge-domain-name: ${JUDGE_DOMAIN_NAME}

judge:
  server:
    ws-judge: wss://${app.default.judge-domain-name}/ws/judge
    https-judge: https://${app.default.judge-domain-name}/judge
    health: https://${app.default.judge-domain-name}/health

springdoc:
  api-docs:
    path: /api-docs
  swagger-ui:
    path: /swagger-ui.html
    operationsSorter: alpha
    defaultModelsExpandDepth: -1

management:
  endpoints:
    web:
      exposure:
        include: "*"
  metrics:
    enable:
      all: true

server:
  servlet:
    session:
      timeout: 30m
      cookie:
        same-site: None
        secure: true
